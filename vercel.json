{
  "version": 2,
  "builds": [
    {
      "src": "meal_buddy/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "meal_buddy/wsgi.py"
    }
  ],
  "buildCommand": "python manage.py collectstatic --noinput",
  "installCommand": "pip install -r requirements.txt",
  "env": {
    "DJANGO_SETTINGS_MODULE": "meal_buddy.settings"
  }
}